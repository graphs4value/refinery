class Person {
    int age
    Person[] children opposite parent
    Person[0..1] parent opposite children
}
declare child, parent.
Person(child).
Person(parent).
age(child): 0..80.
age(parent): 30..30.
parent(child, parent).
error selfParent(Person p) <->
    parent(p, p).
error parentTooYoung(Person child, Person parent) <->
    parent(child, parent),
    age(parent) - age(child) <= 18.
error noParentRelation() <->
    !parent(_, _).