@misc{telbiszMsc2024,
    author = {Telbisz, Csan\'ad},
    title = {Efficient Certifiable Verification of Concurrent Software},
    note = {Students' Scientific Conference, Budapest University of Technology and Economics},
    year = {2024},
    type = {Report},
    url_link = {https://tdk.bme.hu/conference/VIK/2024/sessions/sw/paper/Parhuzamos-programok-hatekony-es-tanusithato},
    abstract = {As multi-core processors gain popularity in safety-critical systems, multi-threaded programs are increasingly used in these systems to exploit their full potential. Concurrency introduces a new level of complexity into software verification due to the great number of possible thread interleavings. Achieving satisfying test coverage is even more challenging, and naive verification techniques often become practically infeasible as a result of this complexity.
                Lately, promising model checking approaches have been developed for the formal verification of concurrent programs that encode the program and the verified property as a Satisfiability Modulo Theories (SMT) problem leaving the reasoning to the strength of SMT solvers. The idea of these methods for concurrent software verification is to ensure that events (variable accesses) of concurrent threads are consistently ordered. Properties are collected that characterize invalid scheduling of concurrent threads and used to exclude invalid program executions. While SMT solvers are optimized in many ways, they remain general purpose tools leaving the room for domain-specific optimization. I propose such an optimization that can find scheduling inconsistencies and strengthen the encoding formula before starting the SMT solving procedure. This way, the solver search space can be greatly reduced and the overall verification performance can be significantly improved.
                Attaching a certificate of correctness to the result of formal verification and the validation of these verification witnesses have been intensely studied. However, practical applicability of these concepts concerning correctness proofs of concurrent software is still very limited. In this work, I propose a novel way to provide and validate correctness witnesses for concurrent program verification. The approach is based on the core concept of event ordering consistency-based verification. I show how those properties characterizing invalid executions can be used as witnesses for the correctness of the program and how they can be validated.}
}
